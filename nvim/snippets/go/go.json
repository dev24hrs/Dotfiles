  "Load .env file": {
    "prefix": "envf",
    "body": [
      "func loadEnv(filename string) error {",
      "\tf, err := os.Open(filename)",
      "\tif err != nil {",
      "\t\treturn fmt.Errorf(\"open env file: %w\", err)",
      "\t}",
      "\tdefer f.Close()",
      "",
      "\tscanner := bufio.NewScanner(f)",
      "\tfor scanner.Scan() {",
      "\t\tline := strings.TrimSpace(scanner.Text())",
      "\t\tif line == \"\" || strings.HasPrefix(line, \"#\") {",
      "\t\t\tcontinue",
      "\t\t}",
      "\t\t// strip inline comments",
      "\t\tif idx := strings.IndexAny(line, \" #\"); idx != -1 {",
      "\t\t\tline = strings.TrimRight(line[:idx], \" \")",
      "\t\t}",
      "\t\t// remove optional export prefix",
      "\t\tline = strings.TrimPrefix(line, \"export \")",
      "\t\tparts := strings.SplitN(line, \"=\", 2)",
      "\t\tif len(parts) != 2 {",
      "\t\t\tcontinue",
      "\t\t}",
      "\t\tkey := strings.TrimSpace(parts[0])",
      "\t\tvalue := strings.TrimSpace(parts[1])",
      "\t\t// strip surrounding quotes (single or double)",
      "\t\tif len(value) >= 2 {",
      "\t\t\tif (value[0] == '\"' && value[len(value)-1] == '\"') ||",
      "\t\t\t\t(value[0] == '\\'' && value[len(value)-1] == '\\'') {",
      "\t\t\t\tvalue = value[1 : len(value)-1]",
      "\t\t\t}",
      "\t\t}",
      "\t\tos.Setenv(key, value)",
      "\t}",
      "\treturn scanner.Err()",
      "}",
      "${0}"
    ],
    "description": "Load .env file (robust: handles quotes, inline comments, export prefix, \\r\\n)"
  },
