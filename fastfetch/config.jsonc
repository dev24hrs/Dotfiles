      "key": "в”‚ в”њв•ґ п„‰  Host",
      "keyColor": "yellow",
    },
    {
      "type": "cpu",
      "key": "в”‚ в”њв•ґ п‹›  CPU",
      "showPeCoreCount": true,
      "format": "{1}",
      "keyColor": "yellow",
    },
    {
