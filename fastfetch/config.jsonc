    },
    {
      "type": "custom",
      "format": "в”Њ{$1}п†’{$1}в”Ђ",
      "outputColor": "90",
    },
    {
      "type": "custom",
      "key": "у°‡… Hardware",
      "keyColor": "yellow",
    },
