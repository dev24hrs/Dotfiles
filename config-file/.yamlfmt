# .yamlfmt

# 格式化器配置
formatter:
  type: basic

  # 缩进设置
  indent: 2  # 2 空格缩进（YAML 标准）
  indentless_arrays: false  # 数组元素缩进（推荐 false）

  # 文档格式
  include_document_start: false  # 不强制添加 ---
  retain_line_breaks: true  # 保留有意义的空行
  disallow_anchors: false  # 允许使用锚点和别名

  # 行格式
  max_line_length: 100  # 最大行长度
  line_ending: lf  # Unix 风格换行符
  trim_trailing_whitespace: true  # 删除行尾空格
  eof_newline: true  # 文件末尾保留空行

  # 特殊处理
  scan_folded_as_literal: false  # 折叠块按字面量处理
  drop_merge_tag: false  # 保留 << 合并标签
  pad_line_comments: 2  # 注释前填充空格数

# 排除路径（glob 模式）
exclude:
  - vendor/**
  - node_modules/**
  - .git/**
  - '**/charts/**'  # Helm charts 目录
  - '**/.terraform/**'  # Terraform 目录
  - '**/generated/**'  # 自动生成的文件

# 包含路径（可选，默认所有 .yaml/.yml）
# include:
#   - '**/*.yaml'
#   - '**/*.yml'

# 扩展名配置
extensions:
  - yaml
  - yml

# Git 集成（可选）
# gitignore_excludes: true       # 自动排除 .gitignore 中的文件
# gitignore_path: .gitignore
